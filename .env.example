# ============================================================
# Vitrin - Docker Environment Variables
# ============================================================
# Bu dosyayı kopyalayarak .env oluşturun:
#   cp .env.example .env
# Ardından kendi değerlerinizle doldurun.
# UYARI: .env dosyasını asla git'e commit etmeyin!
# ============================================================

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=vitrin_auth

# ------------------------------------------------------------
# JWT
# ------------------------------------------------------------
JWT_SECRET=CHANGE_ME_VERY_LONG_SECRET_KEY_AT_LEAST_32_CHARS

# ------------------------------------------------------------
# NextAuth
# ------------------------------------------------------------
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_AT_LEAST_32_CHARS
NEXTAUTH_URL=http://localhost:3000

# ------------------------------------------------------------
# OAuth (opsiyonel)
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI (opsiyonel; AI servisi bu değer olmadan sınırlı çalışır)
GEMINI_API_KEY=

# ------------------------------------------------------------
# Cloudinary (ürün görselleri için)
# ------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ------------------------------------------------------------
# Next.js
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000

# Yerel admin yardımcı scriptleri (opsiyonel)
VITRIN_ADMIN_EMAIL=
VITRIN_ADMIN_PASSWORD=
